{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-appflow/refs/heads/main/json-schema/appflow-create-flow-response-schema.json",
  "title": "CreateFlowResponse",
  "description": "CreateFlowResponse schema from Amazon AppFlow API",
  "type": "object",
  "properties": {
    "flowArn": {
      "type": "string",
      "maxLength": 512,
      "example": "arn:aws:appflow:us-east-1:123456789012:flow/my-salesforce-to-s3-flow",
      "description": "The flow's Amazon Resource Name (ARN)."
    },
    "flowStatus": {
      "type": "string",
      "enum": [
        "Active",
        "Deprecated",
        "Deleted",
        "Draft",
        "Errored",
        "Suspended"
      ],
      "example": "Active",
      "description": "Indicates the current status of the flow."
    }
  }
}